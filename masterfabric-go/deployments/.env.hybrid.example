# Copy to .env.hybrid — hybrid Render + local MLC stack.
# Generate a strong key: openssl rand -hex 32

MLC_API_KEY=change-me-to-a-long-random-secret

# Real MLC override only (docker-compose.hybrid.real-mlc.yml):
# MLC_MODEL=HF://mlc-ai/gemma-2-2b-it-q4f16_1-MLC
# MLC_DEVICE=cuda

MLC_GATEWAY_HOST_BIND=127.0.0.1
MLC_GATEWAY_PORT=8787

# Cloudflare Tunnel token (dashboard → Zero Trust → Tunnels → your tunnel → Install connector)
# Route public hostname → http://mlc-gateway:80 inside Docker network.
CLOUDFLARE_TUNNEL_TOKEN=

PROMETHEUS_HOST_BIND=127.0.0.1
PROMETHEUS_PORT=9090

GRAFANA_HOST_BIND=127.0.0.1
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
