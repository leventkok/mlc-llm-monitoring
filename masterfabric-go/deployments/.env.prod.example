# Copy to .env.prod — 24/7 VPS stack (inferreview.com).
# Generate: openssl rand -hex 32

MLC_API_KEY=change-me-to-a-long-random-secret

# Same tunnel token as Cloudflare Zero Trust (inferreview-hybrid).
# Public routes: mlc.inferreview.com -> mlc-gateway:80, grafana.inferreview.com -> grafana:3000
CLOUDFLARE_TUNNEL_TOKEN=

MLC_GATEWAY_HOST_BIND=127.0.0.1
MLC_GATEWAY_PORT=8787

PROMETHEUS_HOST_BIND=127.0.0.1
PROMETHEUS_PORT=9090

GRAFANA_HOST_BIND=127.0.0.1
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-strong-password
GRAFANA_ROOT_URL=https://grafana.inferreview.com
